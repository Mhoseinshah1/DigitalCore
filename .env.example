# =============================================================================
# DigitalCore — environment configuration (Phase 1)
# =============================================================================
# Copy this file to .env and adjust the values:
#
#     cp .env.example .env
#
# .env is gitignored and must never be committed. This file is safe to commit.
# =============================================================================

# --- Application ---
PROJECT_NAME=DigitalCore
APP_ENV=development
APP_VERSION=0.1.0
API_HOST=0.0.0.0
API_PORT=8000

# --- Database (PostgreSQL) ---
POSTGRES_DB=digitalcore
POSTGRES_USER=digitalcore
POSTGRES_PASSWORD=digitalcore_password
DATABASE_URL=postgresql+asyncpg://digitalcore:digitalcore_password@postgres:5432/digitalcore

# --- Cache (Redis) ---
REDIS_URL=redis://redis:6379/0

# --- Secrets / crypto ---
# SECRET_KEY: app secret; also seeds the Fernet key when FERNET_KEY is blank.
SECRET_KEY=change_me
# FERNET_KEY: urlsafe base64 (32 bytes) used to encrypt secret settings at rest.
# Leave blank in dev to derive one from SECRET_KEY.
FERNET_KEY=
# BACKUP_ENCRYPTION_KEY: reserved for encrypted backups (later phase).
BACKUP_ENCRYPTION_KEY=
# WEB_PANEL_URL: public URL of the admin panel (used by later phases).
WEB_PANEL_URL=

# --- Logging ---
# LOG_LEVEL: one of DEBUG, INFO, WARNING, ERROR, CRITICAL.
LOG_LEVEL=INFO

# --- Auth / admin bootstrap ---
# Change JWT_SECRET and ADMIN_PASSWORD before any real deployment.
JWT_SECRET=change_me
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me

# --- Telegram bot (optional in Phase 1) ---
# The backend runs fine with these empty. The bot service exits cleanly if the
# token is missing.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_ID=

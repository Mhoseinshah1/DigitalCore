# =============================================================================
# DigitalCore environment configuration
# =============================================================================
#
# This file is split into two clearly separated sections:
#
#   1. BOOT SETTINGS      – everything the platform needs to start for the first
#                           time. The one-command installer (./install.sh) fills
#                           these in. They live in this file / the environment.
#
#   2. BUSINESS SETTINGS  – card numbers, channels, plans, texts, etc.
#                           These are NOT required to boot and MUST be configured
#                           later from the admin web panel or the Telegram admin
#                           panel. The keys below only exist as optional defaults
#                           and are intentionally left empty.
#
# Rule for all future phases:
#   Do not add business settings to the installer / boot section unless they are
#   genuinely required for first boot. The installer only boots the platform;
#   the admin panel configures the business.
# =============================================================================


# -----------------------------------------------------------------------------
# 1. BOOT SETTINGS  (required to start the platform)
# -----------------------------------------------------------------------------

# Telegram bot token issued by @BotFather.
BOT_TOKEN=

# Telegram numeric ID of the main (owner) admin. This account is created as the
# initial owner admin and can log in to the web panel.
MAIN_ADMIN_TELEGRAM_ID=

# Comma-separated list of admin Telegram IDs. The installer defaults this to
# MAIN_ADMIN_TELEGRAM_ID. Additional admins are managed from the panel later.
ADMIN_TELEGRAM_IDS=

# Public domain of the web panel (e.g. panel.example.com), without scheme.
DOMAIN=

# Full public URL of the web panel. Derived from DOMAIN by the installer.
WEB_PANEL_URL=

# --- Datastores -------------------------------------------------------------

POSTGRES_USER=digitalcore
POSTGRES_PASSWORD=
POSTGRES_DB=digitalcore

# Async SQLAlchemy DSN. Uses the compose service name "postgres" as the host.
# The installer fills this in from the POSTGRES_* values above.
DATABASE_URL=

# Redis connection URL. Uses the compose service name "redis" as the host.
REDIS_URL=redis://redis:6379/0

# --- Secrets (auto-generated by the installer) ------------------------------

# Application secret key (sessions, CSRF, signing).
SECRET_KEY=

# Secret used to sign web-panel JWT access tokens.
JWT_SECRET=

# Fernet key used to encrypt sensitive settings at rest (urlsafe base64, 32 bytes).
FERNET_KEY=

# Fernet key used to encrypt database backups (urlsafe base64, 32 bytes).
BACKUP_ENCRYPTION_KEY=

# --- Runtime flags ----------------------------------------------------------

# When true, the bot and panel show a maintenance notice. Editable from the panel.
MAINTENANCE_MODE=false


# -----------------------------------------------------------------------------
# 2. BUSINESS SETTINGS  (optional defaults – configure from the admin panel)
# -----------------------------------------------------------------------------
#
# These keys are OPTIONAL and MUST stay empty here. They are seeded into the
# database as editable settings records on first boot and are configured from
# the admin web panel or Telegram admin panel. They are listed here only so an
# operator who wants to pre-seed a value in an automated deployment can do so.
#
# The installer does NOT prompt for any of these.

LOG_GROUP_ID=
FORCE_JOIN_CHANNEL=
DEFAULT_CARD_NUMBER=
DEFAULT_CARD_OWNER=
DEFAULT_SHEBA=
